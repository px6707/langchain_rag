# Copy to backend/.env and fill in API keys before: docker compose up -d --build
# cp .env.docker.example .env

# LLM (OpenAI compatible) — required
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# Embedding — required for retrieval
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# Docker service hostnames (override localhost defaults)
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag
CHECKPOINTER_DATABASE_URL=postgresql://rag:rag@postgres:5432/rag
ES_URL=http://elasticsearch:9200
ES_INDEX=rag_documents

UPLOAD_DIR=/app/uploads
OPENVIKING_PATH=/app/openviking_data
CHUNKING_CONFIG_PATH=./chunking_config.yaml

# Dev SMTP (Mailpit container)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false

# CORS (comma-separated; nginx proxy usually makes this unnecessary)
CORS_ORIGINS=http://localhost:5170,http://127.0.0.1:5170

# JWT / seed admin
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional: MinerU cloud parsing
MINERU_API_TOKEN=

# LangSmith (tracing auto-enabled when API key is set; project defaults to rag-{APP_ENV})
APP_ENV=dev
# LANGSMITH_API_KEY=lsv2_pt_xxx
# LANGSMITH_PROJECT=rag-dev
# LANGSMITH_TRACING_ENABLED=false
# LANGSMITH_METADATA_SNIPPET_CHARS=300
# LANGSMITH_STAGE_TRACING_ENABLED=true

# Docker build mirrors (Compose variable substitution; override for direct Docker Hub)
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-slim-bookworm
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16
# Host port mapping (change if 5433/9200 already in use, e.g. old langchain_rag stack)
# POSTGRES_HOST_PORT=5433
# ES_HOST_PORT=9200
# office-oxide wheels are cp311-only; Docker images use Python 3.11 on Debian bookworm
# parse-worker installs ffmpeg as static binary (see Dockerfile.worker)
# Overseas: PYTHON_BASE_IMAGE=python:3.11-slim  POSTGRES_IMAGE=postgres:16
