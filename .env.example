# LLM (OpenAI compatible)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# Small LLM (retrieval routing, query rewrite, grounding validation, etc.)
# Falls back to LLM_* when unset
# SMALL_LLM_API_BASE=https://api.openai.com/v1
# SMALL_LLM_API_KEY=sk-xxx
# SMALL_LLM_MODEL=gpt-4o-mini
SMALL_LLM_TEMPERATURE=0

# Embedding (separate OpenAI compatible API)
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL（默认端口 5433，避免与本机 PostgreSQL 冲突）
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5433/rag
CHECKPOINTER_DATABASE_URL=postgresql://rag:rag@localhost:5433/rag

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=rag_documents

# RAG retrieval (hybrid ES + cloud rerank)
RETRIEVAL_HYBRID_ENABLED=true
RETRIEVAL_RRF_ENABLED=true
RETRIEVAL_FETCH_K=20
RETRIEVAL_SCORE_THRESHOLD=0.7
RERANK_ENABLED=true
# RERANK_API_BASE=https://api.example.com/v1
# RERANK_API_KEY=sk-xxx
# RERANK_MODEL=your-rerank-model
RERANK_TOP_N=4
RETRIEVAL_PAGE_EXPAND_ENABLED=true
RETRIEVAL_PAGE_EXPAND_MAX_CHUNKS=32

# Answer grounding validation (small LLM structured judge)
GROUNDING_ENABLED=true
GROUNDING_MIN_SUPPORTED_RATIO=0.8
GROUNDING_FAIL_RATIO=0.5
GROUNDING_MAX_CLAIMS=8

# Upload directory
UPLOAD_DIR=./uploads
PARSE_MAX_FILE_MB=200
PARSE_WORKER_POLL_SEC=2
PARSE_MAX_ATTEMPTS=3
PARSE_JOB_STALE_TIMEOUT_SEC=7200
TABLE_CHUNK_ROWS=8
CHUNKING_CONFIG_PATH=./chunking_config.yaml
INDEX_DELETE_RETRY_ATTEMPTS=3

# MinerU cloud parsing
MINERU_API_BASE=https://mineru.net
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SEC=5
MINERU_POLL_TIMEOUT_SEC=3600

# ASR (OpenAI compatible /v1/audio/transcriptions)
# ASR_API_BASE=https://api.openai.com/v1
# ASR_API_KEY=sk-xxx
ASR_MODEL=whisper-1
ASR_USE_VERBOSE_JSON=true
ASR_FALLBACK_SEGMENT_SEC=120

# VLM image/video frame summary (falls back to LLM_*)
# VLM_API_BASE=https://api.openai.com/v1
# VLM_API_KEY=sk-xxx
# VLM_MODEL=gpt-4o-mini

# Video frame extraction
VIDEO_FRAME_MODE=scene
VIDEO_SCENE_THRESHOLD=0.3
VIDEO_FRAME_INTERVAL_SEC=30
VIDEO_MAX_FRAMES=60
VIDEO_FRAME_CONCURRENCY=4
VIDEO_DEDUPE_ENABLED=true
VIDEO_DEDUPE_HAMMING_THRESHOLD=5

# SMTP (send_email tool)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true

# LangSmith (optional observability)
# Get API key: https://smith.langchain.com/settings
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=langchain-rag
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # optional, for self-hosted

# MCP (Model Context Protocol)
MCP_ENABLED=true
MCP_SERVERS_FILE=./mcp_servers.json
# MCP_TOOL_ALLOWLIST=math_add,math_multiply
# MCP HTTP auth (per-server, referenced by mcp_servers.json auth.*_env)
# MCP_WEATHER_TOKEN=
# MCP_PARTNER_API_KEY=
# MCP_LEGACY_USER=
# MCP_LEGACY_PASS=

# JWT authentication
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Seed admin (created on first startup when no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Skill scripts (run_skill_script tool)
SKILL_SCRIPT_ENABLED=true
SKILL_SCRIPT_TIMEOUT_SECONDS=30
SKILL_SCRIPT_MAX_TIMEOUT_SECONDS=300
SKILL_SCRIPT_MAX_OUTPUT_BYTES=512000
SKILL_SCRIPT_MAX_FILE_BYTES=1048576
SKILL_SCRIPT_ALLOWED_EXTENSIONS=.py,.sh
# HITL_TOOLS 默认含 run_skill_script，执行前需用户批准

# OpenViking (embedded long-term memory, includes preferences/profile)
OPENVIKING_ENABLED=false
OPENVIKING_PATH=./openviking_data
# OPENVIKING_CONFIG_FILE=~/.openviking/ov.conf
OPENVIKING_ACCOUNT_ID=default
OPENVIKING_FIND_LIMIT=5
OPENVIKING_FIND_SCORE_THRESHOLD=0.3
OPENVIKING_COMMIT_EVERY_MESSAGES=20
