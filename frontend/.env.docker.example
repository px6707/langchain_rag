# Docker Compose reads this file for build-time image mirrors (optional).
# Copy to .env in this directory: cp .env.docker.example .env
#
# Overseas / direct Docker Hub access — uncomment:
# NODE_BASE_IMAGE=node:20-alpine
# NGINX_BASE_IMAGE=nginx:alpine

NODE_BASE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
NGINX_BASE_IMAGE=docker.m.daocloud.io/library/nginx:alpine
